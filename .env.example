# ============================================================
# YouTube Auto Publisher - Variaveis de Ambiente
# Copie este arquivo para .env e preencha suas credenciais
# ============================================================

# --- PEXELS API ---
PEXELS_API_KEY=your_pexels_api_key_here
PEXELS_TIMEOUT_SECONDS=30
PEXELS_MAX_DOWNLOAD_MB=200

# --- GROQ API ---
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-70b-8192
GROQ_TTS_MODEL=playai-tts
GROQ_TTS_VOICE=Fritz-PlayAI

# --- MISTRAL AI API ---
MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_MODEL=mistral-large-latest

# --- YOUTUBE DATA API v3 ---
YOUTUBE_CLIENT_ID=your_youtube_client_id
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret
YOUTUBE_TOKEN_JSON=
YOUTUBE_REDIRECT_URI=http://localhost:8080
YOUTUBE_TOKEN_FILE=token.json
YOUTUBE_CREDENTIALS_FILE=credentials.json

# --- CONFIGURACOES DE VIDEO ---
VIDEO_LANGUAGE=pt-BR
VIDEO_CATEGORY_ID=22
VIDEO_PRIVACY_STATUS=public
VIDEO_WIDTH=1920
VIDEO_HEIGHT=1080
VIDEO_DURATION=60
VIDEO_NUM_CLIPS=5
VIDEO_MAX_DURATION=60
VIDEO_MIN_DURATION=30
VIDEO_MAX_CLIPS=8
VIDEO_RESOLUTION=1920x1080
VIDEO_FPS=30

# --- CONFIGURACOES DE AUDIO ---
AUDIO_SAMPLE_RATE=44100
AUDIO_CHANNELS=2
AUDIO_VOICE_VOLUME=1.0
AUDIO_MUSIC_VOLUME=0.3
AUDIO_FADE_DURATION=2

# --- CONFIGURACOES DE LEGENDA ---
SUBTITLE_FONT=Arial
SUBTITLE_FONT_SIZE=48
SUBTITLE_COLOR=white
SUBTITLE_STROKE_COLOR=black
SUBTITLE_STROKE_WIDTH=2
SUBTITLE_POSITION=bottom

# --- CAMINHOS ---
OUTPUT_DIR=./output
TEMP_DIR=./temp
MUSIC_DIR=./assets/music
FONTS_DIR=./assets/fonts

# --- CONFIGURACOES DE PUBLICACAO ---
PUBLISH_SCHEDULE=0 10 * * *
PUBLISH_TIMES=08:00,12:00,17:00,20:00
MAX_VIDEOS_PER_DAY=3
ENABLE_AUTO_PUBLISH=true

# --- BANCO DE DADOS ---
DATABASE_URL=sqlite:///./data/videos.db
REDIS_URL=redis://localhost:6379/0

# --- LOGS ---
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
MAX_UPLOAD_RETRIES=6
UPLOAD_RETRY_MAX_SLEEP_SECONDS=64
HTTP_USER_AGENT=youtube-auto-publisher/1.0
